{
  "name": "lsa-desktop",
  "version": "0.0.5",
  "description": "An Electron application for lot sizing in material requirement planning.",
  "main": "./out/main/index.js",
  "author": "hudabrilian",
  "homepage": "https://hudabrilian.com/lsa",
  "scripts": {
    "format": "prettier --write './**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}'",
    "format:check": "prettier --check './**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}'",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:linux": "pnpm build && electron-builder --linux",
    "deploy": "pnpm build && electron-builder build --mac --win --publish always",
    "prepare": "husky"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "builder-util-runtime": "^9.5.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@mantine/charts": "^9.2.2",
    "@mantine/core": "^9.2.2",
    "@mantine/form": "^9.2.2",
    "@mantine/hooks": "^9.2.2",
    "@mantine/modals": "^9.2.2",
    "@mantine/notifications": "^9.2.2",
    "@mantine/nprogress": "^9.2.2",
    "@matejmazur/react-katex": "^3.1.3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-katex": "^3.0.4",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "katex": "^0.17.0",
    "lint-staged": "^17.0.5",
    "lucide-react": "^1.17.0",
    "mathjs": "^15.2.0",
    "nanoid": "^5.1.11",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-organizational-chart": "^2.2.1",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "zustand": "^5.0.14"
  },
  "packageManager": "pnpm@9.12.3+sha1.4fb96925d434c491285182acf29803bb9aa2e6e5",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs,cts,mts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
